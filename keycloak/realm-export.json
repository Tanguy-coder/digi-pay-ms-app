{
  "realm": "digipay",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "USER", "description": "Standard platform user" },
      { "name": "ADMIN", "description": "Platform administrator" }
    ]
  },
  "clients": [
    {
      "clientId": "digipay-gateway",
      "enabled": true,
      "publicClient": false,
      "secret": "digipay-gateway-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": ["http://localhost:8888/*"],
      "webOrigins": ["http://localhost:8888"],
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "roles"],
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "user1",
      "enabled": true,
      "email": "user1@digipay.dev",
      "firstName": "User",
      "lastName": "One",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["USER"]
    },
    {
      "username": "admin1",
      "enabled": true,
      "email": "admin1@digipay.dev",
      "firstName": "Admin",
      "lastName": "One",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["USER", "ADMIN"]
    }
  ]
}
